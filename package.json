{
  "name": "super-mario-og",
  "displayName": "Super Mario",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yash-Dodani/Super-mario.git"
  },
  "description": "The ultimate developer break! Play the original NES Super Mario Bros directly in VS Code with sound and save states.",
  "version": "1.0.0",
  "publisher": "Yash-Dodani",
  "author": {
    "name": "Yash Dodani",
    "url": "https://yashdodani.me"
  },
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "super-mario-og.play",
        "title": "Play Super Mario OG"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "super-mario-og.play",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "eslint": "^8.28.0",
    "glob": "^8.0.3",
    "mocha": "^10.1.0",
    "typescript": "^4.9.3",
    "@vscode/test-electron": "^2.2.0"
  }
}
